# AI Infrastructure Configuration
# Copy this file to .env and fill in your own values

# LLM Model to use (required)
MY_LLM_MODEL=<your-model-id>

# LLM Gateway endpoint (required)
MY_LLM_ENDPOINT=<your-gateway-url>

# Path to JWT token file (required)
MY_TOKEN_FILE=<path-to-token-file>

# Path to token refresh script (required)
MY_TOKEN_REFRESH_SCRIPT=<path-to-refresh-script>
