# OpenAI Compatible API (Alibaba Cloud DashScope / Bailian)
# DASHSCOPE_API_KEY is used by DashScope ASR and Embedding.
# OPENAI_API_KEY remains a supported alias when using one shared API key.
# Keep real keys out of git.
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
OPENAI_API_KEY=

# LLM chat endpoint. For Alibaba Cloud Bailian/DashScope OpenAI-compatible mode,
# use the compatible-mode URL below. Do not use DASHSCOPE_BASE_URL here.
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Model Config. Embedding uses the DashScope SDK and does not use OPENAI_BASE_URL.
LLM_MODEL=qwen3-max
EMBEDDING_MODEL=text-embedding-v4
# Use an extra LLM call to classify each chat question before retrieval.
# Keep false for faster first-token latency.
CHAT_USE_LLM_ROUTER=false

# Frontend API endpoint. For local Docker deployment, keep the default.
NEXT_PUBLIC_API_URL=http://localhost:8000

# DashScope ASR endpoint. This is used by ASR only, not by OpenAI-compatible chat.
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
ASR_MODEL=paraformer-v2
ASR_TIMEOUT=600

# Retrieval tuning
# Candidate chunks recalled before fusion/rerank. Increase for higher recall, lower for speed/cost.
RETRIEVAL_CANDIDATE_K=24
RETRIEVAL_TOP_K=8
RETRIEVAL_MMR_FETCH_K=32
RETRIEVAL_MMR_LAMBDA=0.55
ASR_MODEL_LOCAL=paraformer-realtime-v2
ASR_INPUT_FORMAT=pcm

# App Config
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/bilibili_rag.db

# ChromaDB
CHROMA_PERSIST_DIRECTORY=./data/chroma_db
