# ============================================================
#  LexReviewer — Environment Variables
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
# ============================================================


# ── Required: External API Keys ─────────────────────────────
# OpenAI — used for LLM chat and text-embedding-3-large embeddings
OPENAI_API_KEY=sk-...

# Unstructured.io — used for PDF parsing, chunking, and bounding boxes
UNSTRUCTURED_API_KEY=your-unstructured-api-key


# ── Application ──────────────────────────────────────────────
CHATBOT_NAME=LexReviewer

# LLM model for the main agent (e.g. gpt-4o, gpt-4.1-mini)
AGENT_MODEL=gpt-4o

# LLM model for the reasoning / planning agent
REASONING_AGENT_MODEL=gpt-4o 

# Set to "true" to enable extended reasoning mode for the agent
AGENT_REASONING_ALLOWED=false


# ── OpenAI Models ────────────────────────────────────────────
# Model used to summarise long chat histories
OPENAI_CHAT_SUMMARY_MODEL=gpt-4o-mini

# Model used to summarise individual document chunks at index time
OPENAI_CHUNK_SUMMARY_MODEL=gpt-4o-mini

# Model used to select which retrieval tools are needed per query
REQUIRED_TOOLS_GENERATOR_MODEL=gpt-4o-mini

# Embedding model — vector size must match QDRANT_VECTOR_SIZE below
OPENAI_EMBEDDING_MODEL_NAME=text-embedding-3-large


# ── MongoDB ──────────────────────────────────────────────────
# When using Docker Compose this is overridden to mongodb://mongo:27017
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=lexreviewer
MONGODB_CHAT_HISTORY_COLLECTION_NAME=chat_history
MONGODB_DOC_STORE_COLLECTION_NAME=doc_store


# ── Qdrant ───────────────────────────────────────────────────
# When using Docker Compose this is overridden to http://qdrant:6333
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                        # leave blank for local / no-auth Qdrant
QDRANT_TIMEOUT=60
QDRANT_COLLECTION_NAME=documents

# Must match the output dimension of OPENAI_EMBEDDING_MODEL_NAME
# text-embedding-3-large → 3072
QDRANT_VECTOR_SIZE=3072


# ── Unstructured.io Options ──────────────────────────────────
# Maximum characters per chunk (leave blank to use Unstructured default)
UNSTRUCTURED_MAX_CHARACTERS=
# Character overlap between consecutive chunks
UNSTRUCTURED_OVERLAP=
# Chunking strategy: "by_title" | "basic" (leave blank for default)
UNSTRUCTURED_STRATEGY=


# ── Linked Documents ─────────────────────────────────────────
# Base URL of the external service that resolves cross-document references
# (e.g. amendments, schedules referenced inside a contract)
# Leave blank to disable linked-document retrieval
LINKED_DOCUMENT_FETCH_URL=


# ── Observability (all optional) ─────────────────────────────
# Sentry — error tracking and performance monitoring
SENTRY_DSN=

# Langfuse — LLM tracing and prompt management
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
