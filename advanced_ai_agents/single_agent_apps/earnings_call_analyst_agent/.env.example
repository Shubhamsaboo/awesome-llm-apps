# Option 1: Vertex AI / Google Cloud
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_CLOUD_LOCATION=global

# Option 2: Gemini API key
# GOOGLE_GENAI_USE_VERTEXAI=False
# GOOGLE_API_KEY=your-google-api-key

EARNINGS_GEMINI_MODEL=gemini-3-flash-preview
EARNINGS_SEARCH_GEMINI_MODEL=gemini-2.5-flash
EARNINGS_TRANSCRIPT_MODEL=gemini-3-flash-preview
EARNINGS_AUDIO_CHUNK_SECONDS=300
EARNINGS_USER_AGENT="earnings-call-analyst-agent contact@example.com"
